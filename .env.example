# Supabase 配置（必需）
# 这些变量需要 NEXT_PUBLIC_ 前缀因为 Supabase 客户端需要在浏览器端初始化
# 在 Supabase Dashboard -> Project Settings -> API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 仅服务端使用，绝不能添加 NEXT_PUBLIC_ 前缀
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DMX API（AI 生成服务）- 服务端专用，不要添加 NEXT_PUBLIC_ 前缀
# 这些密钥通过 API 路由代理使用，不会暴露到浏览器
DMX_API_KEY=your-dmx-api-key

# 302.AI Suno 音乐生成（服务端专用）
AI302_API_KEY=your-302-api-key
AI302_BASE_URL=https://api.302ai.com

# Cloudflare R2（文件托管）- 服务端专用，不要添加 NEXT_PUBLIC_ 前缀
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_BUCKET=your-r2-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# 必须是浏览器和外部模型服务可访问的公开域名，例如 R2 public bucket.dev URL 或自定义域名
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com

# Agent 配置 - 服务端专用
AGENT_MODEL=gpt-5-mini

# OpenClaw 配置 - 服务端专用（如需使用）
OPENCLAW_BASE_URL=wss://your-openclaw-endpoint
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_MODEL=agent:main:main

# OpenRouter API - 服务端专用（备用文本生成）
OPENROUTER_API_KEY=sk-or-v1-your-key

# Deep Agents API - 服务端专用
# 使用 Modal 部署的 Deep Agents 服务
DEEPAGENTS_BASE_URL=https://heterocat--deepagents-modal-web.modal.run

# Deep Agents 默认模型
# 可选值: openai:gpt-4o, openai:gpt-4o-mini, anthropic:claude-sonnet-4-6, deepseek:deepseek-chat 等
DEEPAGENTS_MODEL=openai:gpt-4o

# Muses Agent 模型（独立于画布生成模型）
# 可选值: deepseek:deepseek-v4-flash, deepseek:deepseek-v4-pro, openai:gpt-4o
DeepSeek_API_KEY=your-deepseek-api-key
MUSES_AGENT_MODEL=deepseek:deepseek-v4-flash

# Agent 沙盒执行（服务端专用）
# 配置 E2B_API_KEY 后默认启用 E2B 沙盒；如需禁用可设 AGENT_SANDBOX_PROVIDER=none
E2B_API_KEY=your-e2b-api-key
AGENT_SANDBOX_PROVIDER=e2b
# Build with: npm run e2b:build-template
# The template uses Template().fromNodeImage("22") so sandboxes start with Node.js v22+.
E2B_SANDBOX_TEMPLATE=muses-node22
E2B_SANDBOX_CWD=/home/user/musesAOS
E2B_SANDBOX_TIMEOUT_MS=3600000

# Waffo Pancake 支付（服务端专用；私钥绝不能添加 NEXT_PUBLIC_ 前缀）
WAFFO_MERCHANT_ID=your-waffo-merchant-id
WAFFO_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WAFFO_ENVIRONMENT=prod
# 可选：覆盖商品 ID
WAFFO_PRODUCT_STARTER_ID=PROD_xxx
WAFFO_PRODUCT_VALUE_ID=PROD_xxx
