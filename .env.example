# Supabase 配置（必需）
# 这些变量需要 NEXT_PUBLIC_ 前缀因为 Supabase 客户端需要在浏览器端初始化
# 在 Supabase Dashboard -> Project Settings -> API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# DMX API（AI 生成服务）- 服务端专用，不要添加 NEXT_PUBLIC_ 前缀
# 这些密钥通过 API 路由代理使用，不会暴露到浏览器
DMX_API_KEY=your-dmx-api-key
DMX_DOUBAO_TEXT_MODEL=doubao-1.6-chat

# Cloudflare R2（文件托管）- 服务端专用，不要添加 NEXT_PUBLIC_ 前缀
R2_ACCOUNT_ID=4b707dcf025c337cca8d81f26929f781
R2_ENDPOINT=https://4b707dcf025c337cca8d81f26929f781.r2.cloudflarestorage.com
R2_BUCKET=test
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# 必须是浏览器和外部模型服务可访问的公开域名，例如 R2 public bucket.dev URL 或自定义域名
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com

# Agent 配置 - 服务端专用
AGENT_MODEL=gpt-5-mini

# OpenClaw 配置 - 服务端专用（如需使用）
OPENCLAW_BASE_URL=wss://your-openclaw-endpoint
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_MODEL=agent:main:main

# OpenRouter API - 服务端专用（备用文本生成）
OPENROUTER_API_KEY=sk-or-v1-your-key

# Deep Agents API - 服务端专用
# 使用 Modal 部署的 Deep Agents 服务
DEEPAGENTS_BASE_URL=https://heterocat--deepagents-modal-web.modal.run

# Deep Agents 默认模型
# 可选值: openai:gpt-4o, openai:gpt-4o-mini, anthropic:claude-sonnet-4-6, deepseek:deepseek-chat 等
DEEPAGENTS_MODEL=openai:gpt-4o
